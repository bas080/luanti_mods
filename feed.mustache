<?xml version="1.0" encoding="UTF-8" ?>
<rss version="2.0">
<channel>
  <title>Luanti Mods Feed</title>
  <link>https://yourdomain.org/</link>
  <description>Latest Luanti mods from Github, Gitlab, and Codeberg</description>
  <image>
    <url>data:image/svg+xml;base64,</url>
    <title>Luanti Mods Feed</title>
    <link>https://yourdomain.org/</link>
  </image>

  {{#items}}
  <item>
    <title>{{repo_name}} ({{hosted_on}})</title>
    <link>{{{html_url}}}</link>
    <guid>{{{html_url}}}</guid>
    <description><![CDATA[
      <img src="{{{avatar_url}}}" alt="Author avatar" width="32" height="32" style="vertical-align:middle;margin-right:5px;" />
      <strong>{{author}}</strong><br>
      {{description}}<br>
      License: {{license.name}}<br>
      <a href="{{{zip_url}}}">Download ZIP</a><br>
      <img src="{{{image_raw}}}" alt="Mod screenshot" style="max-width:100%;margin-top:5px;" />
    ]]></description>
    <enclosure url="{{{image_raw}}}" type="image/png" />
    <pubDate>{{updated_at}}</pubDate>
  </item>
  {{/items}}
</channel>
</rss>
