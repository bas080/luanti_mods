<html lang="en">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<meta property="og:title" content="Luanti Mods Feed">
<meta property="og:description" content="A feed of Luanti mods from GitHub, GitLab, and Codeberg. See latest updates.">
<meta property="og:type" content="website">
<meta property="og:url" content="https://bas080.github.io/luanti_mods/">
<meta property="og:image" content="https://bas080.github.io/luanti_mods/og-image.png">
<meta property="og:site_name" content="Luanti Mods">
<meta property="og:locale" content="en_US">

<link rel="icon" type="image/svg+xml" href="./favicon.svg">
<title>Luanti Mods</title>
<link rel="stylesheet" href="https://cdn.simplecss.org/simple.min.css">

<style>
  .topic  {
    margin-right: 1vw;
  }
  .topic-badge {
    display: inline-block;
    background-color: var(--secondary);
    color: var(--text);
    margin: 1ch 6ch 1ch 0;
    border-radius: 3px;
  }

  html {
    scroll-behavior: initial !important;
  }
</style>


<style>
  * article {
    border: none;
    margin-top: 8rem;
    padding: 0;
  }

  .relative {
    position: relative;
  }

  figure img {
    min-width: 100%;
  }
</style>

  <style>

    .box-shadow {
      box-shadow: 0 0 6rem var(--text);
    }

    * h2 {
      position: absolute;
      z-index: 10;
      bottom: 0;
      margin: 0;
      background-color: var(--bg);
      padding: 1rem 2rem 1rem 0;
      box-shadow: 0 0 6rem var(--bg);
      border-radius: 0 var(--standard-border-radius) 0 0;
      margin: 0;
    }

    code {
      border: var(--border-width) solid var(--border);
      background-color: var(--accent-bg);
      padding-left: 0.5ch;
      padding-right: 0.5ch;
    }

    .links > * {
      margin-right: 1vw;
    }

    h2 > img {
      height:1em;
      vertical-align:middle;
    }
  </style>

</head>

<body>

  <h1>Luanti Mods</h1>

<p>
  Aggregated <time data-duration data-largest-unit="hour" data-smallest-unit="minute" datetime="{{now}}">{{now}}</time> ago using Github topic <code>luanti-mod</code>, the Gitlab topic <code>Luanti</code> and the Codeberg query <code>luanti-mod</code>.
</p>

<p>
  Subscribe to the <a href="./feed.xml" target="_blank" rel="noopener">📻 RSS feed</a>
</p>

<main role="main">
{{#items}}


<article id="{{full_name}}">

  <div class="relative">

    <h2>
      <img src="{{{avatar_url}}}" alt="Avatar of {{author}}" />
      {{repo_name}}
    </h2>    

    <figure>

<img src="{{{image_raw}}}"
     alt="Screenshot of {{full_name}} mod"
     width="600" height="400"
     loading="lazy"
     onerror="this.onerror=null;this.src='./favicon.svg';">    
    </figure>
  </div>

  <p class="links">
    {{#website}}<a href="{{{website}}}" target="_blank" rel="noopener">Webpage</a>{{/website}}
    <a href="{{{html_url}}}" target="_blank" rel="noopener">{{hosted_on}}</a>
    <a href="{{{issues_url}}}" target="_blank" rel="noopener">Issues{{#open_issues}}[{{open_issues}}]{{/open_issues}}</a>
    <a href="https://content.luanti.org/packages/{{{full_name}}}" class="check-url" target="_blank" rel="noopener">ContentDB</a>
    <a href="{{{html_url}}}/archive/{{default_branch}}.zip" download="{{{repo_name}}}.zip" target="_blank" rel="noopener" title="Download Zip">Download</a>
    <a href="#{{full_name}}" class="share-link" title="Click to copy this article's URL">Share</a>
  </p>

  {{#description}}
  <p>{{description}}</p>
  {{/description}}

  <dl>
    {{#license}}
    <dt>License<dt>
    <dd>{{license.name}}</dd>
    {{/license}}

    <dt>Updated</dt>
    <dd>
      <time data-duration data-largest-unit="month" data-smallest-unit="hour" data-style="long" datetime="{{updated_at}}">{{updated_at}}</time>
      </dd>


    {{#has_stats}}
    <dt>Stats</dt>
    <dd>
      {{#stars}}⭐ {{stars}}{{/stars}}{{#stars}}{{#forks}} · {{/forks}}{{/stars}}
      {{#forks}}🍴 {{forks}}{{/forks}}{{#forks}}{{#open_issues}} · {{/open_issues}}{{/forks}}
      {{#open_issues}}🐞 {{open_issues}}{{/open_issues}}
    </dd>
    {{/has_stats}}

    <dt>Topics</dt>

    <dd>
    {{#topics}}
    {{#.}}<code class="topic">{{.}}</code>{{/.}}
    {{/topics}}
    </dd>

    <dt>Author</dt>
    <dd>
    {{author}}
    </dd>
    
  </dl>

</article>
{{/items}}

<a id="refresh-btn" href="?v={{{now}}}" aria-label="Refresh" hidden>⟳</a>

<style>

#refresh-btn {
  position: fixed;
  bottom: 1.5rem;
  right: 1.5rem;

  width: 52px;
  height: 52px;

  display: flex;
  align-items: center;
  justify-content: center;

  border-radius: 50%;
  border: 1px solid rgba(255, 255, 255, 0.2);

  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(10px);

  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);

  cursor: pointer;
  transition: all 0.2s ease;
}

#refresh-btn:hover {
  background: rgba(255, 255, 255, 0.15);
  transform: translateY(-2px);
}


</style>

<script type="module">
const btn = document.getElementById("refresh-btn");

let lastCheck = Number(localStorage.getItem("lastCheck") || 0);
const MIN_INTERVAL = 10 * 60 * 1000; // 10m


async function check() {
  const now = Date.now();
  if (now - lastCheck < MIN_INTERVAL) return;

  localStorage.setItem("lastCheck", now);

  try {
    const res = await fetch("./", {
      method: "HEAD",
      cache: "no-cache"
    });

    if (res.status === 200) {
      btn.hidden = false;
    }
  } catch (e) {
    console.error(e);
  }
}

check();

window.addEventListener("focus", check);
document.addEventListener("visibilitychange", () => {
  if (document.visibilityState === "visible") check();
});
</script>
</main>

<footer>
  <p><a href="https://github.com/bas080/luanti_mods">https://github.com/bas080/luanti_mods</a></p>
</footer>
</body>

<script type="module">

function updateDurations() {
  const now = new Date();

  document.querySelectorAll("time[data-duration]").forEach(el => {
    const str = el.getAttribute("datetime") || el.textContent;
    if (!str) return;

    const date = new Date(str);
    if (isNaN(date)) {
      console.warn("Failed to parse date:", str);
      return;
    }

    let diffSec = (now - date) / 1000;

    const units = [
      { name: "year", seconds: 31536000 },
      { name: "month", seconds: 2592000 },
      { name: "day", seconds: 86400 },
      { name: "hour", seconds: 3600 },
      { name: "minute", seconds: 60 },
      { name: "second", seconds: 1 },
    ];

    for (const { name, seconds } of units) {
      const val = Math.floor(diffSec / seconds);
      if (Math.abs(val) >= 1) {
        const rtf = new Intl.RelativeTimeFormat(navigator.language, { numeric: "auto" });
        el.textContent = rtf.format(-val, name);
        return;
      }
    }

    el.textContent = "just now";
  });
}

// run once immediately
updateDurations();

window.addEventListener("focus", updateDurations);
document.addEventListener("visibilitychange", () => {
  if (document.visibilityState === "visible") updateDurations();
});

</script>

<script>
document.querySelectorAll(".share-link").forEach(link => {
  link.addEventListener("click", async (e) => {
    e.preventDefault();
    const url = window.location.origin + window.location.pathname + link.getAttribute("href");
    try {
      await navigator.clipboard.writeText(url);
      link.textContent = "Copied!";
      setTimeout(() => link.textContent = "Share", 1500);
    } catch (err) {
      console.error("Failed to copy URL:", err);
      alert("Failed to copy URL. Right-click and copy manually.");
    }
  });
});
</script>

</html>
